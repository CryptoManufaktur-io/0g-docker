# The settings are in .env, use "nano .env". Don't edit default.env itself.
ENV_VERSION=5

# Compose files to use (colon-separated)
# Add :ext-network.yml for Traefik integration
# Add :rpc-shared.yml to expose RPC ports locally
COMPOSE_FILE=0g.yml

# Project name - used for container naming and Docker volume prefixes
PROJECT_NAME=0g

# 0G Aristotle mainnet
NETWORK=aristotle
CHAIN_ID=16661
MONIKER=0g-node

# Build targets
ZEROG_VERSION=1.0.4

# Snapshot URL for initial sync (leave empty to sync from genesis)
# Supported formats: .tar.lz4, .tar.gz, .tar.zst, .tar
SNAPSHOT=

# Ports
RPC_PORT=8545
WS_PORT=8546
AUTH_RPC_PORT=8551
GETH_ENGINE_HOST=geth
GETH_P2P_PORT=30303
GETH_METRICS_PORT=9001
CL_RPC_PORT=26657
CL_P2P_PORT=26656
CL_METRICS_PORT=26660

# Leave empty or set to "auto" to resolve the host public IPv4 at startup.
# Set to "none" to skip explicit P2P endpoint advertisement.
P2P_EXTERNAL_IP=
INIT_WAIT_TIMEOUT=600

# Public/reference RPC used by ./ethd check-sync
PUBLIC_RPC=https://evmrpc.0g.ai
BLOCK_LAG_THRESHOLD=5

# Logging: info, debug, warn, error
LOG_LEVEL=info

# Additional command-line flags
GETH_EXTRA_FLAGS=
CL_EXTRA_FLAGS=

# Secure web proxy - requires Traefik
DOMAIN=cryptomanufaktur.net
RPC_HOST=0g
RPC_LB=0g-lb
WS_HOST=0gws
WS_LB=0gws-lb

# External Docker network name for reverse proxy / monitoring
DOCKER_EXT_NETWORK=traefik_default

# Pin this repo to a specific git tag (leave empty for latest main)
SCRIPT_TAG=
